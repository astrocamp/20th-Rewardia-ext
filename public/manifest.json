{
  "manifest_version": 3,
  "name": "Rewardia",
  "version": "1.0.0",
  "description": "Rewardia Chrome Extension",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rewardia"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost:8000/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}