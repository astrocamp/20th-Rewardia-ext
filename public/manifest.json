{
  "manifest_version": 3,
  "name": "Rewardia",
  "version": "2.0.0",
  "description": "Rewardia Chrome Extension",
  "action": {
    "default_popup": "/src/popup/popup.html",
    "default_title": "Rewardia"
  },
  "content_scripts": [
    {
      "matches": ["*://www.eslite.com/*","*://www.klook.com/*","*://24h.pchome.com.tw/*","*://www.momoshop.com.tw/*","*://cart.momoshop.com.tw/*", "https://www.kkday.com/*","https://shopee.tw/*","https://rewardia.net/*","http://localhost:8000/*","https://bsp.momoshop.com.tw/*"],
      "js": ["content.js"],
      "css": ["content_script.css"]
    },
    {
      "matches": ["*://bsp.momoshop.com.tw/*"],
      "js": ["iframe.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://rewardia.net/*",
    "http://localhost:8000/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}