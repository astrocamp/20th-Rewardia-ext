{
  "manifest_version": 3,
  "name": "Rewardia",
  "version": "1.0.0",
  "description": "Rewardia Chrome Extension",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Rewardia"
  },
  "content_scripts": [
    {
      "matches": ["*://www.eslite.com/*","*://www.klook.com/*","*://24h.pchome.com.tw/*","*://www.momoshop.com.tw/*","*://cart.momoshop.com.tw/*", "https://rewardia.net/*","http://localhost:8000/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://rewardia.net/*",
    "http://localhost:8000/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}