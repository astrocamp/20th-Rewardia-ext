{
  "name": "Rewardia",
  "description": "信用卡回饋比較網站，一張卡，省下你的每一塊",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": "images/logo.png"
  },
  "permissions":["storage","activeTab","tabs"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://*/*",
    "https://*/*"
  ]
}