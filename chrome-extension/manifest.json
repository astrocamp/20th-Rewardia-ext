{
  "name": "Rewardia",
  "description": "信用卡回饋比較網站，一張卡，省下你的每一塊",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup/pages/rewards.html",
    "default_icon": "images/Rewardia.png"
  },
  "permissions":["storage","tabs"],
  "host_permissions": [
    "https://rewardia.net/*"
  ],

 "content_scripts": [
   {
     "matches": ["*://www.eslite.com/*","*://www.klook.com/*","*://24h.pchome.com.tw/*","*://www.momoshop.com.tw/*","*://cart.momoshop.com.tw/*", "https://rewardia.net/*"],
     "css": ["content_scripts/content_script.css"],
     "js": ["content_scripts/content_script.js"]
   }
 ],
 "web_accessible_resources": [
  {"resources": ["images/*"],
      "matches": ["<all_urls>"]}
],

"background": {
    "service_worker": "background.js"
  }
}
